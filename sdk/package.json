{
  "name": "@jitter/sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "package.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build":     "tsc -p tsconfig.json",
    "audit:contract": "node ./scripts/audit-contract-surface.mjs",
    "dev":       "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "codegen":   "sui-ts-codegen generate && node ./scripts/fix-generated-imports.mjs",
    "typecheck": "tsc --noEmit",
    "test":      "bun test src/test",
    "test:integration": "bun test src/test/simulation.test.ts"
  },
  "dependencies": {
    "@mysten/sui": "^2.14.1"
  },
  "devDependencies": {
    "@mysten/codegen": "^0.8.5",
    "@types/node": "^20",
    "bun-types": "^1.3.10",
    "typescript": "^5"
  }
}
